{
  "expo": {
    "name": "PropManager",
    "slug": "property-app",
    "scheme": "prop-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.curefit.propmanager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFD700"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.curefit.propmanager",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ]
,
    "extra": {
      "eas": {
        "projectId": "e4acc725-f7bf-47df-bee4-92eceabc7677"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e4acc725-f7bf-47df-bee4-92eceabc7677"
    }
  }
}
